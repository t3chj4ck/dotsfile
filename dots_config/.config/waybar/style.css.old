/* @import "mocha_gtk.css"; */

* {
  border: 5px;
  border-radius: 0;
  font-family:Hack;
  font-size: 10px;
}

window#waybar {
  /* background-color: rgb(0,0,0); */
  background-color: transparent;
  /*border-radius: 10px; */
  /* border: 2px solid #ffffff; */
}



window#waybar.hidden {
  opacity: 0.5;
}

#workspaces {
  transition-duration: 0.5s;
}

#waybar .modules-right{
  /* background-color: rgba(0,0,0,0.9); */
  border-radius: 0px;
  /* border-bottom:1px solid @maroon; */
  color:white
  /* color:@maroon; */
}
#waybar .modules-center{
  /* background-color: rgba(0,0,0,0.9); */
  border-radius: 0px;
  /* border-bottom:1px solid @peach; */
  /* color: @peach; */
  color:white
}
#waybar .modules-left {
  /* background-color: rgba(0,0,0,0.9); */
  border-radius: 0px;
  background-color:transparent;
  /* border-bottom: 1px solid @sky; */
  /* color: @sky; */
  color :white
}



#workspaces button {
  all: initial;
  /* Remove GTK theme values (waybar #1351) */
  min-width: 0;
  /* Fix weird spacing in materia (waybar #450) */
  /* box-shadow: inset 0 -3px transparent; */
  /* Use box-shadow instead of border so the text isn't offset */
  padding: 0px 18px;
  margin: 0px 0px;
  border: 2px solid white;
  /* text-shadow:
    0 0 2px rgba(137, 220, 235, 0.6),
    0 0 4px rgba(137, 220, 235, 0.4),
    0 0 8px rgba(137, 220, 235, 0.3); */
  color: white;
  background-color: black;
  /* box-shadow:
    0 0 3px 1px rgba(137, 220, 235, 0.6),
    0 0 6px 2px rgba(137, 220, 235, 0.4),
    inset 0 0 3px rgba(137, 220, 235, 0.3); */
}

#workspaces button.active {
  color:rgba(0, 0, 0, 0.8);
  background-color: #ffffff;
}

#workspaces button:hover {
  background-color: #ffffff;
  color: black;
}

#workspaces button.urgent {
  background-color: #f38ba8;
}
#battery,
#backlight,
#wireplumber,
#network,
#custom-power_status,
#battery.charging,
#network,
#clock,
#temperature,
#cpu,
#memory {
  margin: 0px 0px;
  padding: 0px 12px;
  background-color: rgba(0, 0, 0, 1);
  /* text-shadow:
    0 0 2px rgba(250, 179, 135, 0.6),
    0 0 4px rgba(250, 179, 135, 0.4),
    0 0 8px rgba(250, 179, 135, 0.3); */
  border:2px solid white;
  /* box-shadow:
    0 0 3px 1px rgba(250, 179, 135, 0.6),
    0 0 6px 2px rgba(250, 179, 135, 0.4),
    inset 0 0 3px rgba(250, 179, 135, 0.3); */
}



#tray,
#clock,
#custom-clipboard,
#custom-notification,
#custom-wallpaper {
  margin: 0px 0px;
  padding: 0px 12px;
  background-color: rgba(0, 0, 0, 1);
  border:2px solid white;
  /* text-shadow:
    0 0 2px rgba(235, 160, 172, 0.6),
    0 0 4px rgba(235, 160, 172, 0.4),
    0 0 8px rgba(235, 160, 172, 0.3);
  box-shadow:
    0 0 3px 1px rgba(235, 160, 172, 0.6),
    0 0 6px 2px rgba(235, 160, 172, 0.4),
    inset 0 0 3px rgba(235, 160, 172, 0.3); */
}




#battery.warning,
#battery.critical,
#battery.urgent {
  color: #ff0000;
}



tooltip {
  border-radius: 8px;
  padding: 15px;
  background-color: #131822;
}

tooltip label {
  padding: 5px;
  background-color: #131822;
}
