output eDP-1 scale 1.25
set $mod Mod4
set $term alacritty
set $menu rofi -show run


gaps outer 8
gaps inner 4 
for_window [class="^.*"] border pixel 2
client.focused #ffffff #ffffff #ffffff #ffffff




exec waybar &
exec fcitx5 &
exec nm-applet &
exec blueman-applet &
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
exec wl-paste -t text --watch clipman store --max-items=100 --no-persist &
exec wl-gammarelay-rs &
exec swaync &
exec awww-daemon &
exec clash-verge &




floating_modifier $mod

bindsym Print exec --no-startup-id exec sh -c 'mkdir -p ~/Pictures/Screenshots && grim -g "$(slurp)" - | tee ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%m-%S).png | wl-copy && notify-send "screenshot"'



#clipboard
bindsym $mod+v exec "clipman pick -t rofi && notify-send 'done copy'"


bindsym $mod+q exec $term
bindsym $mod+r exec $menu
bindsym Mod1+F4 kill
bindsym $mod+left focus left
bindsym $mod+down focus down
bindsym $mod+up focus up
bindsym $mod+right focus right
bindsym $mod+Shift+left move left
bindsym $mod+Shift+down move down
bindsym $mod+Shift+up move up
bindsym $mod+Shift+right move right
bindsym $mod+f fullscreen toggle
bindsym $mod+h layout toggle split
bindsym $mod+e exec nautilus
bindsym $mod+space floating toggle
bindsym $mod+a focus parent



bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Volume" "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)"%"}')"
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Volume" "$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2*100)"%"}')"
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl s 10%+ && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Brightness" "$(brightnessctl -m | awk -F, '{print $4}')"
bindsym XF86MonBrightnessDown exec brightnessctl s 10%- && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Brightness" "$(brightnessctl -m | awk -F, '{print $4}')"


# Requires playerctl
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPause exec playerctl play-pause
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPrev exec playerctl previous


#redlight
bindsym $mod+Mod1+up exec busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +500 && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Screen Temperature" "$(busctl --user get-property rs.wl-gammarelay / rs.wl.gammarelay Temperature | awk '{print $2"K"}')"
bindsym $mod+Mod1+down exec busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -500 && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -t 1000 "Screen Temperature" "$(busctl --user get-property rs.wl-gammarelay / rs.wl.gammarelay Temperature | awk '{print $2"K"}')"


